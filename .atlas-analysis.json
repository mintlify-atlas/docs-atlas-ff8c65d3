  "keyFeatures": [
    "Multi-agent orchestration and swarm intelligence",
    "Extensible plugin system for custom functionality",
    "Multi-language support (TypeScript, Python, Rust)",
    "Model-agnostic (OpenAI, Anthropic, Llama, Gemini, Grok)",
    "Platform connectors (Discord, Telegram, Slack, Twitter, Farcaster)",
    "RAG (Retrieval-Augmented Generation) with document ingestion",
    "Character-based personality and behavior system",
    "Advanced memory and state management",
    "Real-time streaming responses",
    "Built-in web UI for agent management",
    "CLI tool for scaffolding and project management",
    "REST API for programmatic control"
  ],
  "publicApiSurface": [
    "AgentRuntime - Core runtime class for agent lifecycle",
    "createBootstrapPlugin - Factory for creating bootstrap plugins",
    "Plugin interface - Base interface for extending functionality",
    "Action interface - Define custom agent actions",
    "Evaluator interface - Create custom evaluators",
    "Provider interface - Supply context and data to agents",
    "Character type - Define agent personality and behavior",
    "Memory interface - Manage agent memory and state",
    "Service interface - Extend agent capabilities with services",
    "elizaos CLI - Command-line tool for project management"
  ]
